# PlanterPlan — example client environment
#
# Copy to `.env.local` and fill in values. Only VITE_-prefixed keys ship to the
# browser bundle (Vite convention). Server-only secrets — VAPID_PRIVATE_KEY,
# VAPID_SUBJECT, SUPABASE_SERVICE_ROLE_KEY, EMAIL_PROVIDER_API_KEY,
# RESEND_FROM_ADDRESS — belong in Supabase function secrets, NOT here.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Wave 30 — Web Push (bundle-shipped public key; private key is a Supabase secret)
VITE_VAPID_PUBLIC_KEY=

# ---------------------------------------------------------------------------
# Server-only secrets (DO NOT place here — configure as Supabase function
# secrets via `supabase secrets set`). Listed commented-out so operators
# know the full surface needed for a working deploy.
# ---------------------------------------------------------------------------
#
# SUPABASE_SERVICE_ROLE_KEY=        # All edge functions that write/read cross-tenant.
# VAPID_PRIVATE_KEY=                # dispatch-push.
# VAPID_SUBJECT=mailto:ops@your.tld # dispatch-push.
# EMAIL_PROVIDER_API_KEY=           # Resend API key — supervisor-report + dispatch-notifications + overdue-digest.
# RESEND_FROM_ADDRESS=              # Sender address for the above.
