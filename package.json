{
  "name": "planterplan-alpha",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck:agent": "node scripts/tsc-agent.cjs",
    "db:local:bootstrap": "node scripts/supabase-local-bootstrap.cjs --fresh",
    "db:local:bootstrap:fresh": "node scripts/supabase-local-bootstrap.cjs --fresh",
    "db:local:test": "npm run db:local:bootstrap && npx --no-install supabase test db",
    "db:local:test:fresh": "npm run db:local:bootstrap:fresh && npx --no-install supabase test db",
    "verify-dependencies": "node scripts/verify-dependency-guardrails.cjs",
    "verify-architecture": "node scripts/verify-architecture.cjs",
    "lint": "eslint .",
    "test:e2e": "E2E_RUN_ID=${E2E_RUN_ID:-local-$(date +%s)} playwright test",
    "test:e2e:smoke": "npm run test:e2e -- --project=smoke",
    "test:e2e:regression": "npm run test:e2e -- --project=regression",
    "preview": "vite preview"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.4.0",
    "@radix-ui/react-avatar": "^1.2.2",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-popover": "^1.1.19",
    "@radix-ui/react-progress": "^1.1.12",
    "@radix-ui/react-radio-group": "^1.4.3",
    "@radix-ui/react-select": "^2.3.3",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.3.3",
    "@radix-ui/react-tooltip": "^1.2.12",
    "@supabase/supabase-js": "^2.110.2",
    "@tanstack/react-query": "^5.101.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "gantt-task-react": "0.3.9",
    "i18next": "^26.3.6",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^1.24.0",
    "react": "19.2.7",
    "react-day-picker": "^10.0.1",
    "react-dom": "19.2.7",
    "react-error-boundary": "^6.1.2",
    "react-hook-form": "^7.81.0",
    "react-i18next": "^17.0.9",
    "react-is": "19.2.7",
    "react-router-dom": "^7.18.1",
    "recharts": "^3.9.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "supabase": "2.109.1",
    "typescript": "~7.0.2",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.4"
  }
}
