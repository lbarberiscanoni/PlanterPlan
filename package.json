{
  "name": "planterplan-alpha",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck:agent": "node scripts/tsc-agent.cjs",
    "db:local:bootstrap": "node scripts/supabase-local-bootstrap.cjs --fresh",
    "db:local:bootstrap:fresh": "node scripts/supabase-local-bootstrap.cjs --fresh",
    "db:local:test": "npm run db:local:bootstrap && npx --no-install supabase test db",
    "db:local:test:fresh": "npm run db:local:bootstrap:fresh && npx --no-install supabase test db",
    "verify-dependencies": "node scripts/verify-dependency-guardrails.cjs",
    "verify-architecture": "node scripts/verify-architecture.cjs",
    "lint": "eslint .",
    "test:e2e": "E2E_RUN_ID=${E2E_RUN_ID:-local-$(date +%s)} playwright test",
    "test:e2e:smoke": "npm run test:e2e -- --project=smoke",
    "test:e2e:regression": "npm run test:e2e -- --project=regression",
    "preview": "vite preview"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@supabase/supabase-js": "^2.96.0",
    "@tanstack/react-query": "^5.90.21",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "dompurify": "^3.4.11",
    "gantt-task-react": "0.3.9",
    "i18next": "^23.16.8",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^1.8.0",
    "posthog-js": "^1.399.1",
    "react": "18.3.1",
    "react-day-picker": "^10.0.1",
    "react-dom": "18.3.1",
    "react-error-boundary": "^6.1.1",
    "react-hook-form": "^7.71.2",
    "react-i18next": "^15.7.4",
    "react-is": "18.3.1",
    "react-router-dom": "^7.13.0",
    "recharts": "^3.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.1",
    "tailwindcss": "^4.1.18",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "supabase": "2.95.2",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^8.0.8"
  }
}
