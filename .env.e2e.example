# Copy to .env.e2e and fill in. NEVER commit real keys. Load it before running, e.g.:
#   set -a && source .env.e2e && set +a && npm run test:e2e:smoke

# Deployed app under test (Vercel preview or prod). Local won't work — no reach to remote Supabase.
E2E_BASE_URL=https://your-preview-url.vercel.app

# Seeded test accounts (shared password). These are disposable fixtures.
E2E_PASSWORD=Roots99
E2E_ADMIN_EMAIL=test-user.admin@mail.com
E2E_PLANTER_EMAIL=test-user.planter@mail.com
E2E_TEAM_EMAIL=test-user.team@mail.com

# Cleanup only (globalTeardown). Service-role key = CI secret, never in the client bundle.
# If unset, teardown is SKIPPED and the nightly reaper must catch the leftover tagged data.
E2E_SUPABASE_URL=https://your-project.supabase.co
E2E_SUPABASE_SERVICE_ROLE_KEY=

# Set automatically by `npm run test:e2e` (local) or CI (github.run_id-run_attempt).
# Only set manually if you want a fixed cleanup tag.
# E2E_RUN_ID=
